# Predložak konfiguracije baze. Kopiraj u .env i ispuni stvarnim vrijednostima.
# .env se NE commita (nalazi se u .gitignore).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=promijeni_me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=salon

# JWT autentifikacija
# Generiraj tajni ključ: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=promijeni_me_generiraj_nasumicni_kljuc
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
